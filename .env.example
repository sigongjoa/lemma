# =============================================
# Lemma - 로컬 개발용 환경변수 예시
# 이 파일을 복사해서 .env.local 로 사용하세요
# =============================================

# NextAuth (로컬 개발용, 운영은 Cloudflare Secret으로 관리)
NEXTAUTH_SECRET=local-dev-secret-change-this
NEXTAUTH_URL=http://localhost:3000

# Gemini API (운영은 Cloudflare Secret으로 관리)
GEMINI_API_KEY=your-gemini-api-key-here

# Z3 Solver (선택)
Z3_SERVICE_URL=http://localhost:8000

# =============================================
# 운영(Cloudflare Pages) 시크릿 설정 방법:
# npx wrangler secret put NEXTAUTH_SECRET
# npx wrangler secret put GEMINI_API_KEY
# =============================================
